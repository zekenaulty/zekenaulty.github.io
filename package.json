{
  "name": "zekenaulty.github.io",
  "version": "1.0.0",
  "description": "React/Vite single-page resume site using MUI",
  "private": true,
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prebuild": "npm run build:sitemap && npm run build:resume-chat-data",
    "build:sitemap": "node ./scripts/build-sitemap.js",
    "build:resume-chat-data": "node ./scripts/build-resume-chat-data.js",
    "build:exports": "node ./scripts/build-resume-exports.js",
    "generate:tailored-profiles": "node ./scripts/generate-tailored-profiles.js",
    "writing": "node ./scripts/writing-loop.js",
    "writing:init": "node ./scripts/writing-loop.js init",
    "writing:signals": "node ./scripts/writing-loop.js signals",
    "writing:draft": "node ./scripts/writing-loop.js draft",
    "writing:run": "node ./scripts/writing-loop.js run",
    "writing:test": "node ./scripts/writing-loop.js run --offline --count 2",
    "writing:topics": "node ./scripts/writing-loop.js topics",
    "build:job": "npm run generate:tailored-profiles && npm run build:exports",
    "build:all": "npm run build && npm run build:exports",
    "preview": "vite preview",
    "predeploy": "npm run build:all",
    "deploy": "npm run build:all && gh-pages -d dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zekenaulty/zekenaulty.github.io.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/zekenaulty/zekenaulty.github.io/issues"
  },
  "homepage": "https://zekenaulty.github.io/",
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.20",
    "@mui/material": "^5.15.20",
    "animejs": "^3.2.1",
    "docx": "^9.1.0",
    "dotenv": "^16.6.1",
    "pdfkit": "^0.15.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "gh-pages": "^6.3.0",
    "vite": "^7.2.4"
  }
}
